# ====================================================
# Enterprise RAG Platform - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ====================================================

# --- NextAuth ---
# Secret used to sign JWTs. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# Public URL of the Next.js app (used by NextAuth callbacks)
NEXTAUTH_URL=http://localhost:3000

# --- OIDC / OAuth Provider ---
# Client ID from your OIDC provider (e.g., Keycloak, Auth0, Google)
OIDC_CLIENT_ID=your_oidc_client_id_here
OIDC_CLIENT_SECRET=your_oidc_client_secret_here
OIDC_ISSUER=https://your-oidc-provider.com/realms/your-realm

# --- Database ---
# Connection string for the primary relational database
DATABASE_URL=postgresql://user:password@localhost:5432/enterprise_rag

# --- Qdrant Vector DB ---
QDRANT_HOST=vector-db
QDRANT_PORT=6333

# --- LLM / Embedding Model (optional, add provider keys as needed) ---
# OPENAI_API_KEY=sk-...
# COHERE_API_KEY=...
